---
interface Props {
	title: string;
	description: string;
	actionHref?: string;
	actionLabel?: string;
}

const { title, description, actionHref, actionLabel } = Astro.props;
---

<div class="surface-card px-6 py-7 text-sm leading-7 text-ink/72 sm:px-8">
	<p class="protocol-title text-[1.7rem] leading-tight text-ink">{title}</p>
	<p class="mt-3 max-w-2xl">{description}</p>
	{
		actionHref && actionLabel && (
			<a href={actionHref} class="protocol-link mt-5">
				{actionLabel}
			</a>
		)
	}
</div>
