---
interface Props {
	kicker: string;
	title: string;
	intro: string;
	asideTitle?: string;
	aside?: string;
	primaryCta?: {
		label: string;
		href: string;
	};
	secondaryCta?: {
		label: string;
		href: string;
	};
}

const { kicker, title, intro, asideTitle, aside, primaryCta, secondaryCta } = Astro.props;
---

<section class="grid gap-8 pt-8 lg:grid-cols-[minmax(0,1fr)_18rem]">
	<div class="editorial-rule">
		<p class="section-label">{kicker}</p>
		<h1 class="mt-5 max-w-4xl text-[2.9rem] leading-[0.94] sm:text-[4rem] lg:text-[4.8rem]">
			{title}
		</h1>
		<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78 sm:text-[1.18rem]">
			{intro}
		</p>
		{
			(primaryCta || secondaryCta) && (
				<div class="mt-8 flex flex-wrap gap-5">
					{primaryCta && (
						<a
							href={primaryCta.href}
							class="inline-flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-ink no-underline transition hover:text-rust"
						>
							<span aria-hidden="true">→</span>
							{primaryCta.label}
						</a>
					)}
					{secondaryCta && (
						<a
							href={secondaryCta.href}
							class="inline-flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-ash no-underline transition hover:text-rust"
						>
							<span aria-hidden="true">→</span>
							{secondaryCta.label}
						</a>
					)}
				</div>
			)
		}
	</div>

	{
		aside && (
			<aside class="editorial-rule lg:mt-16">
				<p class="section-label">{asideTitle ?? 'System note'}</p>
				<p class="mt-4 text-[1.02rem] leading-8 text-ink/76">{aside}</p>
			</aside>
		)
	}
</section>
