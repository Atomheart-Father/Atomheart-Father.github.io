---
interface Props {
	kicker: string;
	title: string;
	intro: string;
	asideTitle?: string;
	aside?: string;
	primaryCta?: {
		label: string;
		href: string;
	};
	secondaryCta?: {
		label: string;
		href: string;
	};
}

const { kicker, title, intro, asideTitle, aside, primaryCta, secondaryCta } = Astro.props;
---

<section class="grid gap-6 pt-6 lg:grid-cols-[1fr_0.46fr]">
	<div class="surface-card px-6 py-7 sm:px-8 sm:py-10">
		<p class="section-label">{kicker}</p>
		<h1 class="mt-5 max-w-4xl text-[2.9rem] leading-[0.96] sm:text-[4rem] lg:text-[4.6rem]">
			{title}
		</h1>
		<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78 sm:text-[1.18rem]">
			{intro}
		</p>
		{
			(primaryCta || secondaryCta) && (
				<div class="mt-8 flex flex-wrap gap-3">
					{primaryCta && (
						<a href={primaryCta.href} class="rounded-full bg-ink px-5 py-3 text-sm tracking-[0.12em] text-paper no-underline transition hover:bg-shadow">
							{primaryCta.label}
						</a>
					)}
					{secondaryCta && (
						<a href={secondaryCta.href} class="rounded-full border border-black/10 px-5 py-3 text-sm tracking-[0.12em] text-ash no-underline transition hover:bg-white/70 hover:text-ink">
							{secondaryCta.label}
						</a>
					)}
				</div>
			)
		}
	</div>

	{
		aside && (
			<aside class="surface-card px-6 py-7 sm:px-8 sm:py-10">
				<p class="section-label">{asideTitle ?? 'System note'}</p>
				<p class="mt-4 text-[1.02rem] leading-8 text-ink/76">{aside}</p>
			</aside>
		)
	}
</section>
