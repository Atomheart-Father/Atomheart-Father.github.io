---
interface Props {
	kicker: string;
	title: string;
	intro: string;
	asideTitle?: string;
	aside?: string;
}

const { kicker, title, intro, asideTitle, aside } = Astro.props;
---

<section class="grid gap-6 pt-6 lg:grid-cols-[1fr_0.46fr]">
	<div class="surface-card px-6 py-7 sm:px-8 sm:py-10">
		<p class="section-label">{kicker}</p>
		<h1 class="mt-5 max-w-4xl text-[2.9rem] leading-[0.96] sm:text-[4rem] lg:text-[4.6rem]">
			{title}
		</h1>
		<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78 sm:text-[1.18rem]">
			{intro}
		</p>
	</div>

	{
		aside && (
			<aside class="surface-card px-6 py-7 sm:px-8 sm:py-10">
				<p class="section-label">{asideTitle ?? 'System note'}</p>
				<p class="mt-4 text-[1.02rem] leading-8 text-ink/76">{aside}</p>
			</aside>
		)
	}
</section>
