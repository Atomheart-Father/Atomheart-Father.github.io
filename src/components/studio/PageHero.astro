---
interface Props {
	kicker: string;
	title: string;
	intro: string;
	asideTitle?: string;
	aside?: string;
	primaryCta?: {
		label: string;
		href: string;
	};
	secondaryCta?: {
		label: string;
		href: string;
	};
}

const { kicker, title, intro, asideTitle, aside, primaryCta, secondaryCta } = Astro.props;
---

<section class="grid gap-8 pt-10 lg:grid-cols-[minmax(0,1fr)_22rem]">
	<div class="editorial-rule">
		<p class="section-label">{kicker}</p>
		<h1 class="protocol-title mt-5 max-w-5xl text-[3rem] leading-[0.9] sm:text-[4.8rem] lg:text-[6.3rem]">
			{title}
		</h1>
		<p class="mt-6 max-w-3xl text-[1.14rem] leading-8 text-ink/76 sm:text-[1.3rem]">
			{intro}
		</p>
		{
			(primaryCta || secondaryCta) && (
				<div class="mt-8 flex flex-wrap gap-5">
					{primaryCta && (
						<a
							href={primaryCta.href}
							class="protocol-link text-ink hover:text-rust"
						>
							<span aria-hidden="true">→</span>
							{primaryCta.label}
						</a>
					)}
					{secondaryCta && (
						<a
							href={secondaryCta.href}
							class="protocol-link text-ash"
						>
							<span aria-hidden="true">→</span>
							{secondaryCta.label}
						</a>
					)}
				</div>
			)
		}
	</div>

	{
		aside && (
			<aside class="protocol-field min-h-[20rem] p-5 lg:mt-16">
				<p class="section-label">{asideTitle ?? 'System note'}</p>
				<p class="mt-24 max-w-[18rem] text-[1rem] leading-7 text-ink/76">{aside}</p>
			</aside>
		)
	}
</section>
