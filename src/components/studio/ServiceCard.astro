---
import type { ServiceEntry } from '../../lib/content-api';

interface Props {
	service: ServiceEntry;
	index?: number;
}

const { service, index } = Astro.props;
const numberLabel = String(index ?? 0).padStart(2, '0');
---

<article id={service.data.slug} class="border-t border-black/80 py-9">
	<div class="grid gap-6 lg:grid-cols-[4.5rem_minmax(0,1fr)]">
		<div class="font-mono text-[0.82rem] uppercase text-ash">{numberLabel}</div>
		<div class="grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(18rem,0.95fr)]">
			<div>
				<p class="section-label">Front door</p>
				<h2 class="protocol-title mt-14 max-w-3xl text-[2.35rem] leading-[0.92] sm:text-[3.35rem]">{service.data.title}</h2>
				<p class="mt-5 max-w-3xl text-[1.04rem] leading-8 text-ink/76">{service.data.summary}</p>
				<a
					href={service.data.ctaHref}
					class="protocol-link mt-6"
				>
					<span aria-hidden="true">→</span>
					{service.data.ctaLabel}
				</a>
			</div>

			<div class="grid gap-5 sm:grid-cols-2">
				<div class="surface-inset pt-4">
					<p class="section-label">Good fit</p>
					<ul class="mt-4 space-y-3 text-sm leading-6 text-ink/74">
						{service.data.idealFor.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<div class="surface-inset pt-4">
					<p class="section-label">Deliverables</p>
					<ul class="mt-4 space-y-3 text-sm leading-6 text-ink/74">
						{service.data.deliverables.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<div class="surface-inset pt-4">
					<p class="section-label">Boundaries</p>
					<ul class="mt-4 space-y-3 text-sm leading-6 text-ink/74">
						{service.data.boundaries.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<div class="surface-inset pt-4">
					<p class="section-label">Can lead to</p>
					<ul class="mt-4 space-y-3 text-sm leading-6 text-ink/74">
						{service.data.upgradePaths.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			</div>
		</div>
	</div>
</article>
