---
import { footerCopy, primaryNav, siteMeta } from '../lib/site';
---

<footer class="mt-24 pb-8 pt-10">
	<div class="grid gap-8 border-t border-black/80 pt-8 lg:grid-cols-[1.25fr_0.7fr_0.8fr]">
		<div class="space-y-3">
			<p class="section-label">CHLOMEE STUDIO</p>
			<p class="max-w-2xl font-mono text-[0.72rem] uppercase leading-6 text-ink/78">
				{footerCopy}
			</p>
		</div>

		<div class="space-y-3">
			<p class="section-label">Navigate</p>
			<ul class="space-y-2 font-mono text-[0.72rem] uppercase text-ash">
				{
					primaryNav.map((item) => (
						<li>
							<a href={item.href} class="hover:text-rust">
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</div>

		<div class="space-y-3">
			<p class="section-label">Links</p>
			<ul class="space-y-2 font-mono text-[0.72rem] uppercase text-ash">
				<li>
					<a href={`mailto:${siteMeta.email}`} class="hover:text-rust">{siteMeta.email}</a>
				</li>
				<li>
					<a href={siteMeta.orcid} target="_blank" rel="noreferrer" class="hover:text-rust">ORCID</a>
				</li>
				<li>
					<a href={siteMeta.github} target="_blank" rel="noreferrer" class="hover:text-rust">GitHub</a>
				</li>
			</ul>
		</div>
	</div>
</footer>
