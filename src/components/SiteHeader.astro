---
import { primaryNav } from '../lib/site';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
	if (href === '/') {
		return pathname === '/';
	}

	return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="sticky top-0 z-40 -mx-5 border-b border-black/80 bg-paper/92 px-5 py-4 backdrop-blur-sm sm:-mx-8 sm:px-8 lg:-mx-10 lg:px-10">
	<div class="mx-auto grid max-w-[1440px] gap-4 lg:grid-cols-[1fr_auto] lg:items-center">
		<a href="/" class="font-mono text-[0.72rem] uppercase text-ink no-underline">
			<span>CHLOMEE STUDIO</span>
			<span class="mx-2 text-ash">/</span>
			<span>Work Field</span>
		</a>

		<nav aria-label="Primary" class="w-full lg:w-auto">
			<ul class="flex flex-wrap gap-x-5 gap-y-2 lg:justify-end">
				{
					primaryNav.map((item) => (
						<li>
							<a
								href={item.href}
								aria-current={isActive(item.href) ? 'page' : undefined}
								class:list={[
									'font-mono text-[0.72rem] uppercase transition duration-200',
									isActive(item.href)
										? 'bg-ink px-1 pb-0.5 text-paper'
										: 'text-ink hover:text-rust',
								]}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>
