---
import { primaryNav } from '../lib/site';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
	if (href === '/') {
		return pathname === '/';
	}

	return pathname === href || pathname.startsWith(`${href}/`);
};
---

<header class="sticky top-0 z-40 -mx-5 border-b border-black/8 bg-paper/82 px-5 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 lg:-mx-12 lg:px-12">
	<div class="mx-auto grid max-w-[1400px] gap-4 lg:grid-cols-[1fr_auto] lg:items-end">
		<a href="/" class="flex flex-col gap-1 text-ink no-underline">
			<span class="section-label">Chromi Kingdom</span>
			<span class="font-display text-[1.55rem] leading-none sm:text-[1.8rem]">Research, journal, selective intervention</span>
		</a>

		<nav aria-label="Primary" class="w-full lg:w-auto">
			<ul class="flex flex-wrap gap-x-5 gap-y-2 lg:justify-end">
				{
					primaryNav.map((item) => (
						<li>
							<a
								href={item.href}
								aria-current={isActive(item.href) ? 'page' : undefined}
								class:list={[
									'font-mono text-[0.72rem] uppercase tracking-[0.2em] transition duration-200',
									isActive(item.href)
										? 'text-ink underline decoration-[0.08em] underline-offset-[0.45rem]'
										: 'text-ash hover:text-rust',
								]}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</header>
