---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	href: string;
	title: string;
	typeLabel: string;
	year: number;
	summary: string;
	statusLabel: string;
	themes?: string[];
	cover?: ImageMetadata;
	featured?: boolean;
	filterKey?: string;
}

const {
	href,
	title,
	typeLabel,
	year,
	summary,
	statusLabel,
	themes = [],
	cover,
	featured = false,
	filterKey = 'paper',
} = Astro.props;
---

<article
	class="surface-card group flex h-full flex-col overflow-hidden border-black/35"
	data-filter-key={filterKey}
>
	<a href={href} class="flex h-full flex-col no-underline">
		{
			cover ? (
				<div class="relative overflow-hidden">
					<Image
						src={cover}
						alt=""
						class="h-60 w-full object-cover grayscale transition duration-700 group-hover:scale-[1.015] group-hover:grayscale-0"
					/>
					<div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(7,8,7,0)_0%,rgba(7,8,7,0.2)_100%)]"></div>
				</div>
			) : (
				<div class="visual-well relative h-28 overflow-hidden border-b border-black/20">
					<div class="absolute left-6 top-5 font-mono text-[0.68rem] uppercase text-ash">No public image</div>
					<div class="absolute inset-x-6 bottom-5 h-px bg-black/25"></div>
				</div>
			)
		}

		<div class="flex flex-1 flex-col gap-5 px-5 py-5 sm:px-6">
			<div class="flex flex-wrap items-center gap-3 font-mono text-[0.68rem] uppercase text-ash">
				<span>{typeLabel}</span>
				<span>/</span>
				<span>{year}</span>
				<span>/</span>
				<span>{statusLabel}</span>
			</div>

			<div class="space-y-3">
				<h3 class="protocol-title text-[1.8rem] leading-tight text-ink transition duration-300 group-hover:text-rust">
					{title}
				</h3>
				<p class="text-[1.02rem] leading-7 text-ink/78">{summary}</p>
			</div>

			<div class="mt-auto flex flex-wrap gap-2 pt-1">
				{featured && <span class="border border-rust/40 px-3 py-1 font-mono text-[0.68rem] uppercase text-rust">Featured</span>}
				{
					themes.slice(0, 3).map((theme) => (
						<span class="border border-black/20 px-3 py-1 font-mono text-[0.68rem] uppercase text-ash">
							{theme}
						</span>
					))
				}
			</div>
		</div>
	</a>
</article>
