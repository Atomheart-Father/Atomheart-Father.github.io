---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	href: string;
	title: string;
	typeLabel: string;
	year: number;
	summary: string;
	statusLabel: string;
	themes?: string[];
	cover?: ImageMetadata;
	featured?: boolean;
	filterKey?: string;
}

const {
	href,
	title,
	typeLabel,
	year,
	summary,
	statusLabel,
	themes = [],
	cover,
	featured = false,
	filterKey = 'paper',
} = Astro.props;
---

<article
	class="surface-card group flex h-full flex-col overflow-hidden"
	data-filter-key={filterKey}
>
	<a href={href} class="flex h-full flex-col no-underline">
		{
			cover ? (
				<div class="relative overflow-hidden">
					<Image
						src={cover}
						alt=""
						class="h-60 w-full object-cover transition duration-700 group-hover:scale-[1.02]"
					/>
					<div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(24,20,18,0)_0%,rgba(24,20,18,0.28)_100%)]"></div>
				</div>
			) : (
				<div class="relative h-28 overflow-hidden bg-[linear-gradient(135deg,rgba(255,255,255,0.75),rgba(143,85,71,0.08)_42%,rgba(126,150,160,0.12)_100%)]">
					<div class="absolute inset-y-5 left-6 w-px bg-ink/8"></div>
					<div class="absolute bottom-6 right-8 h-12 w-12 rounded-full border border-rust/25"></div>
					<div class="absolute inset-x-6 top-1/2 h-px bg-ink/8"></div>
				</div>
			)
		}

		<div class="flex flex-1 flex-col gap-5 px-5 py-5 sm:px-6">
			<div class="flex flex-wrap items-center gap-3 text-[0.75rem] uppercase tracking-[0.2em] text-ash">
				<span>{typeLabel}</span>
				<span class="h-1 w-1 rounded-full bg-rust/65"></span>
				<span>{year}</span>
				<span class="h-1 w-1 rounded-full bg-rust/65"></span>
				<span>{statusLabel}</span>
			</div>

			<div class="space-y-3">
				<h3 class="text-[1.8rem] leading-tight text-ink transition duration-300 group-hover:text-rust">
					{title}
				</h3>
				<p class="text-[1.02rem] leading-7 text-ink/78">{summary}</p>
			</div>

			<div class="mt-auto flex flex-wrap gap-2 pt-1">
				{featured && <span class="rounded-full border border-rust/18 bg-rust/9 px-3 py-1 text-xs uppercase tracking-[0.18em] text-rust">Featured</span>}
				{
					themes.slice(0, 3).map((theme) => (
						<span class="rounded-full border border-black/8 px-3 py-1 text-xs tracking-[0.08em] text-ash">
							{theme}
						</span>
					))
				}
			</div>
		</div>
	</a>
</article>
