---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/studio/ContentCard.astro';
import EmptyState from '../components/studio/EmptyState.astro';
import PageHero from '../components/studio/PageHero.astro';
import { getPublicResearch, researchColumns } from '../lib/content-api';

const entries = await getPublicResearch();
const createResearchDescription =
	'Add an entry with npm run new:content -- research "Title", then switch visibility to public when it is ready.';
---

<BaseLayout title="Research" description="Research surface for under-review work, working papers, memos, essays, and notes.">
	<PageHero
		kicker="Research"
		title="A public research surface, not a full archive."
		intro="This page is designed to hold only the work that can support the Studio route: under-review or in-progress research, working papers or memos, and public essays or notes."
		asideTitle="Publishing rule"
		aside="Full manuscripts do not need to be posted here. Abstract-level entries, public samples, and reusable memos are enough until a piece is ready."
	/>

	<section class="mt-12 grid gap-5 lg:grid-cols-3">
		{
			researchColumns.map((column) => {
				const columnEntries = entries.filter((entry) =>
					column.categories.some((category) => category === entry.data.category),
				);

				return (
					<div class="space-y-4">
						<div class="surface-card px-5 py-5">
							<p class="section-label">{column.title}</p>
							<p class="mt-4 text-sm leading-7 text-ink/72">{column.description}</p>
						</div>

						{columnEntries.length > 0 ? (
							columnEntries.map((entry) => (
								<ContentCard
									href={`/research/${entry.data.slug}`}
									kicker={entry.data.status.replaceAll('_', ' ')}
									title={entry.data.title}
									summary={entry.data.summary}
									meta={String(entry.data.year)}
									tags={entry.data.themes}
								/>
							))
						) : (
							<EmptyState
								title="No public entries yet."
								description={createResearchDescription}
							/>
						)}
					</div>
				);
			})
		}
	</section>
</BaseLayout>
