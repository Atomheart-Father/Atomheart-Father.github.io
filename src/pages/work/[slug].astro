---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const entries = await getCollection('work');
	return entries
		.filter((entry) => entry.data.visibility === 'public' && entry.data.status !== 'draft')
		.map((entry) => ({
			params: { slug: entry.data.slug },
			props: { entry },
		}));
}

const { entry } = Astro.props as { entry: CollectionEntry<'work'> };
const { Content } = await render(entry);
const questionnaire = entry.data.questionnaire;
const hasQuestionnaireLink = questionnaire.status === 'external_link' && Boolean(questionnaire.href);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
	<section class="mx-auto max-w-[1080px] space-y-8 pt-6">
		<a href="/work" class="section-label inline-flex items-center gap-3 no-underline transition hover:text-rust">
			<span aria-hidden="true">←</span>
			Back to work
		</a>

		<header class="editorial-rule">
			<p class="section-label">{entry.data.kind.replaceAll('_', ' ')}</p>
			<h1 class="protocol-title mt-5 max-w-5xl text-[3rem] leading-[0.9] sm:text-[5rem]">{entry.data.title}</h1>
			<div class="mt-6 flex flex-wrap gap-2 font-mono text-[0.68rem] uppercase text-ash">
				<span class="border border-black/20 px-3 py-1">{entry.data.year}</span>
				<span class="border border-black/20 px-3 py-1">{entry.data.status}</span>
				<span class="border border-black/20 px-3 py-1">{entry.data.stage}</span>
				{entry.data.themes.map((theme) => <span class="border border-rust/40 px-3 py-1 text-rust">{theme}</span>)}
			</div>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/80">{entry.data.summary}</p>
		</header>

		<section class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem]">
			<article class="copy-prose border-t border-black/35 pt-6">
				<Content />
			</article>

			<aside class="space-y-8">
				<div class="editorial-rule">
					<p class="section-label">Public material boundary</p>
					<ul class="mt-5 space-y-3 font-mono text-[0.72rem] uppercase leading-6 text-ink/74">
						{entry.data.publicMaterials.map((item, index) => (
							<li class="grid grid-cols-[2rem_1fr] gap-3 border-b border-black/18 pb-3">
								<span class="text-ash">{String(index).padStart(2, '0')}</span>
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>

				<div class="protocol-field p-5">
					<p class="section-label">{questionnaire.label}</p>
					<p class="mt-10 font-mono text-[0.72rem] uppercase text-rust">{questionnaire.status.replaceAll('_', ' ')}</p>
					<p class="mt-4 text-[0.96rem] leading-7 text-ink/74">{questionnaire.note}</p>
					{
						hasQuestionnaireLink && (
							<a href={questionnaire.href} class="protocol-link mt-5">
								<span aria-hidden="true">→</span>
								Open questionnaire
							</a>
						)
					}
				</div>

				{
					entry.data.links.length > 0 && (
						<div class="editorial-rule">
							<p class="section-label">Links</p>
							<div class="mt-5 flex flex-col gap-3">
								{entry.data.links.map((link) => (
									<a href={link.href} class="protocol-link">
										<span aria-hidden="true">→</span>
										{link.label}
									</a>
								))}
							</div>
						</div>
					)
				}
			</aside>
		</section>
	</section>
</BaseLayout>
