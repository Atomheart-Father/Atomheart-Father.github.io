---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Notes" description="Notes are not public yet.">
	<section class="mx-auto max-w-[920px] pt-10">
		<div class="editorial-rule">
			<p class="section-label">Notes</p>
			<h1 class="protocol-title mt-5 text-[2.9rem] leading-[0.94] sm:text-[4rem]">Notes moved into Journal.</h1>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78">
				Use Journal for public notes. This legacy route is not part of the current public structure.
			</p>
		</div>

		<a href="/journal" class="protocol-link mt-10">
			<span aria-hidden="true">→</span>
			Open Journal
		</a>
	</section>
</BaseLayout>
