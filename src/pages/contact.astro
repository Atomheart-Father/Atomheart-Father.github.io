---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/studio/PageHero.astro';
import { getActiveServices } from '../lib/content-api';
import { contactPage, siteMeta } from '../lib/site';

const services = await getActiveServices();
---

<BaseLayout title="Contact" description="Contact Chromi Kingdom by email.">
	<PageHero
		kicker={contactPage.hero.kicker}
		title={contactPage.hero.title}
		intro={contactPage.hero.intro}
		asideTitle={contactPage.hero.asideTitle}
		aside={siteMeta.email}
	/>

	<section class:list={['mt-16 grid gap-8', services.length > 0 && 'lg:grid-cols-[0.95fr_1.05fr]']}>
		<div class="editorial-rule">
			<p class="section-label">{contactPage.checklistTitle}</p>
			<ul class="mt-5 space-y-4 font-mono text-[0.82rem] uppercase leading-7 text-ink/76">
				{contactPage.checklist.map((item, index) => (
					<li class="grid grid-cols-[2.4rem_1fr] gap-4 border-b border-black/20 pb-3">
						<span class="text-ash">{String(index).padStart(2, '0')}</span>
						<span>{item}</span>
					</li>
				))}
			</ul>
			<a
				href={`mailto:${siteMeta.email}`}
				class="protocol-link mt-6"
			>
				<span aria-hidden="true">→</span>
				Email {siteMeta.email}
			</a>
		</div>

		{
			services.length > 0 && (
				<div class="editorial-rule">
					<p class="section-label">{contactPage.frontDoorTitle}</p>
					<div class="mt-5 space-y-4">
						{services.map((service) => (
							<a href={`/work#${service.data.slug}`} class="surface-inset block pt-4 text-ink no-underline hover:text-rust">
								<p class="protocol-title text-[1.8rem] leading-[0.92]">{service.data.title}</p>
								<p class="mt-2 text-sm leading-6 text-ink/72">{service.data.summary}</p>
							</a>
						))}
					</div>
				</div>
			)
		}
	</section>
</BaseLayout>
