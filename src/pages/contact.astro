---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/studio/PageHero.astro';
import { contactPage, siteMeta } from '../lib/site';
---

<BaseLayout title="Contact" description="Contact CHLOMEE STUDIO by email.">
	<PageHero
		kicker={contactPage.hero.kicker}
		title={contactPage.hero.title}
		intro={contactPage.hero.intro}
	/>

	<section class="mt-16 grid gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)]">
		<div class="editorial-rule">
			<p class="section-label">Email</p>
			<a
				href={`mailto:${siteMeta.email}`}
				class="mt-5 block font-mono text-[1.1rem] uppercase leading-7 text-rust no-underline transition hover:text-ink"
			>
				{siteMeta.email}
			</a>
		</div>

		<div class="editorial-rule">
			<p class="section-label">{contactPage.noteTitle}</p>
			<ul class="mt-8 flex flex-wrap gap-4 font-mono text-[0.78rem] uppercase text-ash">
				<li>
					<a href={siteMeta.orcid} target="_blank" rel="noreferrer" class="text-rust no-underline transition hover:text-ink">
						ORCID
					</a>
				</li>
				<li>
					<a href={siteMeta.github} target="_blank" rel="noreferrer" class="text-rust no-underline transition hover:text-ink">
						GitHub
					</a>
				</li>
			</ul>
		</div>
	</section>
</BaseLayout>
