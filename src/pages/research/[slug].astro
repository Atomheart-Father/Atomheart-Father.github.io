---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const entries = await getCollection('research');
	return entries
		.filter((entry) => entry.data.visibility === 'public' && entry.data.status !== 'draft')
		.map((entry) => ({
			params: { slug: entry.data.slug },
			props: { entry },
		}));
}

const { entry } = Astro.props as { entry: CollectionEntry<'research'> };
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
	<section class="mx-auto max-w-[920px] space-y-8 pt-6">
		<a href="/research" class="section-label inline-flex items-center gap-3 no-underline transition hover:text-rust">
			<span aria-hidden="true">←</span>
			Back to research
		</a>

		<header class="surface-card px-6 py-7 sm:px-8 sm:py-10">
			<p class="section-label">{entry.data.category.replaceAll('_', ' ')}</p>
			<h1 class="mt-5 text-[2.8rem] leading-[0.98] sm:text-[4rem]">{entry.data.title}</h1>
			<div class="mt-6 flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em] text-ash">
				<span class="rounded-full border border-black/8 px-3 py-1">{entry.data.year}</span>
				<span class="rounded-full border border-black/8 px-3 py-1">{entry.data.status.replaceAll('_', ' ')}</span>
				{entry.data.themes.map((theme) => <span class="rounded-full border border-rust/18 bg-rust/8 px-3 py-1 text-rust">{theme}</span>)}
			</div>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/80">{entry.data.summary}</p>
		</header>

		<article class="copy-prose surface-card px-6 py-7 sm:px-8 sm:py-9">
			<Content />
		</article>
	</section>
</BaseLayout>
