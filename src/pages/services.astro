---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Closed Route" description="This route is not part of the public site.">
	<section class="mx-auto max-w-[920px] pt-10">
		<div class="editorial-rule">
			<p class="section-label">Closed route</p>
			<h1 class="protocol-title mt-5 text-[2.9rem] leading-[0.94] sm:text-[4rem]">This route is not public.</h1>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78">
				The current public site is organized around Work, Journal, About, and Contact.
			</p>
			<a href="/journal" class="protocol-link mt-8">
				<span aria-hidden="true">→</span>
				Open Journal
			</a>
		</div>
	</section>
</BaseLayout>
