---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services" description="No public services are listed yet.">
	<section class="mx-auto max-w-[920px] pt-10">
		<div class="editorial-rule">
			<p class="section-label">Legacy route</p>
			<h1 class="protocol-title mt-5 text-[2.9rem] leading-[0.94] sm:text-[4rem]">No public services are listed yet.</h1>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78">
				This legacy route remains available for older links, but no service offer is public right now.
			</p>
			<a href="/journal" class="protocol-link mt-8">
				<span aria-hidden="true">→</span>
				Open Journal
			</a>
		</div>
	</section>
</BaseLayout>
