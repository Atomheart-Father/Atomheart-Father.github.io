---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Closed Route" description="Closed route.">
	<section class="mx-auto max-w-[920px] pt-10">
		<div class="editorial-rule">
			<p class="section-label">Closed route</p>
			<h1 class="protocol-title mt-5 text-[2.9rem] leading-[0.94] sm:text-[4rem]">Closed.</h1>
			<a href="/journal" class="protocol-link mt-8">
				<span aria-hidden="true">→</span>
				Open Journal
			</a>
		</div>
	</section>
</BaseLayout>
