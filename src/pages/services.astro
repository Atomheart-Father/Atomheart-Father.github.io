---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/studio/PageHero.astro';
import ServiceCard from '../components/studio/ServiceCard.astro';
import { getActiveServices } from '../lib/content-api';
import { servicesPage } from '../lib/site';

const services = await getActiveServices();
---

<BaseLayout title="Services" description="Three bounded front-door services for research-driven AI diagnosis, audit, and briefs.">
	<PageHero
		kicker={servicesPage.hero.kicker}
		title={servicesPage.hero.title}
		intro={servicesPage.hero.intro}
		asideTitle={servicesPage.hero.asideTitle}
		aside={servicesPage.hero.aside}
	/>

	<section class="mt-12 space-y-6">
		{services.map((service) => <ServiceCard service={service} />)}
	</section>
</BaseLayout>
