---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/studio/ContentCard.astro';
import PageHero from '../components/studio/PageHero.astro';
import { getPublishedImageNotes, getPublishedWriting } from '../lib/content-api';
import { journalPage } from '../lib/site';

const writing = await getPublishedWriting();
const imageNotes = await getPublishedImageNotes();
---

<BaseLayout title="Journal" description="Public writing, case notes, and image notes from Boxz Studio.">
	<PageHero
		kicker={journalPage.hero.kicker}
		title={journalPage.hero.title}
		intro={journalPage.hero.intro}
	/>

	<section class="mt-20 grid gap-10 lg:grid-cols-[minmax(0,0.42fr)_minmax(0,1fr)]">
		<div class="editorial-rule">
			<p class="section-label">Index / 01</p>
			<h2 class="protocol-title mt-4 text-[2.8rem] leading-[0.9] sm:text-[4rem]">{journalPage.writingTitle}</h2>
			{
				journalPage.writingIntro && (
					<p class="mt-4 max-w-xl text-[1.02rem] leading-8 text-ink/74">{journalPage.writingIntro}</p>
				)
			}
		</div>

		<div class="border-t border-black/35">
			{
				writing.length > 0 ? writing.map((entry) => (
					<ContentCard
						href={`/journal/${entry.data.slug}`}
						kicker={entry.data.type.replaceAll('_', ' ')}
						title={entry.data.title}
						summary={entry.data.summary}
						meta={entry.data.dateLabel ?? entry.data.date.toISOString().slice(0, 10)}
						tags={entry.data.tags}
					/>
				)) : null
			}
		</div>
	</section>

	{
		imageNotes.length > 0 && (
			<section class="mt-24 grid gap-10 lg:grid-cols-[minmax(0,0.42fr)_minmax(0,1fr)]">
					<div class="editorial-rule">
						<p class="section-label">Index / 02</p>
						<h2 class="protocol-title mt-4 text-[2.8rem] leading-[0.9] sm:text-[4rem]">{journalPage.visualTitle}</h2>
						{
							journalPage.visualIntro && (
								<p class="mt-4 max-w-xl text-[1.02rem] leading-8 text-ink/74">{journalPage.visualIntro}</p>
							)
						}
					</div>

					<div class="border-t border-black/35">
						{imageNotes.map((entry) => (
							<ContentCard
								href={`/journal/${entry.data.slug}`}
								kicker="Image note"
								title={entry.data.title}
								summary={entry.data.summary}
								meta={entry.data.dateLabel ?? entry.data.date.toISOString().slice(0, 10)}
								tags={entry.data.tags}
							/>
						))}
					</div>
			</section>
		)
	}
</BaseLayout>
