---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="The page you were looking for does not exist.">
	<section class="mx-auto max-w-[880px] pt-10">
		<div class="protocol-field px-6 py-10 sm:px-10 sm:py-14">
			<p class="section-label">404</p>
			<h1 class="protocol-title mt-24 text-[3rem] leading-[0.9] sm:text-[5rem]">This route does not hold anything yet.</h1>
			<p class="mx-auto mt-6 max-w-2xl text-[1.04rem] leading-8 text-ink/76">
				The page may have moved, or it may not have been released. The entrance is still nearby.
			</p>
			<div class="mt-8 flex flex-wrap gap-5">
				<a href="/" class="protocol-link text-ink">
					Back home
				</a>
				<a href="/journal" class="protocol-link">
					Open journal
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
