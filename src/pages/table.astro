---
import BaseLayout from '../layouts/BaseLayout.astro';
import { legacyCopy } from '../lib/site';
---

<BaseLayout title="Table" description="A future medium for meals, conversation, and carefully staged encounters.">
	<section class="grid gap-6 pt-6 lg:grid-cols-[1.02fr_0.98fr]">
		<div class="surface-card px-6 py-8 sm:px-8 sm:py-10">
			<p class="section-label">Table</p>
			<h1 class="mt-5 text-[2.9rem] leading-[0.96] sm:text-[4rem]">
				Food will arrive here as a medium, not as an accessory.
			</h1>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78">{legacyCopy.tableLead}</p>
			<p class="mt-4 max-w-3xl text-[1.02rem] leading-8 text-ink/72">{legacyCopy.tableBody}</p>
		</div>

		<div class="surface-card px-6 py-8 sm:px-8 sm:py-10">
			<p class="section-label">Future directions</p>
			<div class="mt-5 space-y-4">
				<div class="surface-inset rounded-[1.4rem] px-5 py-5">
					<p class="font-display text-[1.7rem]">Private dinners</p>
					<p class="mt-3 text-sm leading-7 text-ink/72">
						Small-format meals for conversation, atmosphere, and carefully chosen company.
					</p>
				</div>
				<div class="surface-inset rounded-[1.4rem] px-5 py-5">
					<p class="font-display text-[1.7rem]">Salon formats</p>
					<p class="mt-3 text-sm leading-7 text-ink/72">
						Table as a place where thought and sensorial pacing can shape each other.
					</p>
				</div>
				<div class="surface-inset rounded-[1.4rem] px-5 py-5">
					<p class="font-display text-[1.7rem]">Menus as documents</p>
					<p class="mt-3 text-sm leading-7 text-ink/72">
						Menus, table notes, and eventual archives once the form is ready to be public.
					</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
