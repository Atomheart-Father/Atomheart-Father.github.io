---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Table" description="Table is not public yet.">
	<section class="mx-auto max-w-[920px] pt-10">
		<div class="editorial-rule">
			<p class="section-label">Table</p>
			<h1 class="protocol-title mt-5 text-[2.9rem] leading-[0.94] sm:text-[4rem]">Table is not public yet.</h1>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78">
				This route is reserved for a future format. It is not part of the current public site.
			</p>
		</div>
	</section>
</BaseLayout>
