---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { workPage } from '../../lib/site';
---

<BaseLayout title="Works" description="Public works are not listed yet.">
	<section class="mx-auto max-w-[920px] pt-10">
		<div class="editorial-rule">
			<p class="section-label">Works</p>
			<h1 class="protocol-title mt-5 text-[2.9rem] leading-[0.94] sm:text-[4rem]">Public works are not listed yet.</h1>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78">
				This route is reserved for future public papers, projects, or visual series. Draft manuscripts,
				declined papers, and unfinished formats are not displayed as public work.
			</p>
		</div>

		<div class="mt-10 grid gap-4 sm:grid-cols-2">
			{workPage.bridge.links.map((link) => (
				<a href={link.href} class="protocol-link">
					<span aria-hidden="true">→</span>
					{link.label}
				</a>
			))}
		</div>
	</section>
</BaseLayout>
