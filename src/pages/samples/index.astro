---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Samples" description="Samples are not public yet.">
	<section class="mx-auto max-w-[920px] pt-10">
		<div class="editorial-rule">
			<p class="section-label">Samples</p>
			<h1 class="protocol-title mt-5 text-[2.9rem] leading-[0.94] sm:text-[4rem]">Samples are not public yet.</h1>
			<p class="mt-6 max-w-3xl text-[1.08rem] leading-8 text-ink/78">
				This route is reserved for future public examples. It will stay quiet until there is a real sample
				worth publishing.
			</p>
		</div>
	</section>
</BaseLayout>
