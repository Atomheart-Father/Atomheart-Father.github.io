---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/studio/ContentCard.astro';
import EmptyState from '../../components/studio/EmptyState.astro';
import PageHero from '../../components/studio/PageHero.astro';
import { getPublishedSamples } from '../../lib/content-api';

const samples = await getPublishedSamples();
const createSampleDescription =
	'The interface is ready. Create one with npm run new:content -- sample "Title", write 600-1200 words, then set status to published.';
---

<BaseLayout title="Samples" description="Public samples and method notes for the Studio front door.">
	<PageHero
		kicker="Samples"
		title="Short public assets that prove the method."
		intro="Samples should not read like academic papers. Each one should show a common mistake, how the problem gets decomposed, the minimum advice, and the next step."
		asideTitle="Fixed formats"
		aside="Diagnosis sample. Workflow audit sample. Governance brief sample. Anonymized case note. Everything here should be reusable for outreach."
	/>

	<section class="mt-12">
		{
			samples.length > 0 ? (
				<div class="grid gap-5 lg:grid-cols-2">
					{samples.map((sample) => (
						<ContentCard
							href={`/samples/${sample.data.slug}`}
							kicker={sample.data.template.replaceAll('_', ' ')}
							title={sample.data.title}
							summary={sample.data.summary}
							meta={sample.data.date.toISOString().slice(0, 10)}
							tags={sample.data.tags}
						/>
					))}
				</div>
			) : (
				<EmptyState
					title="No public samples yet."
					description={createSampleDescription}
					actionHref="/services"
					actionLabel="Review the front doors first"
				/>
			)
		}
	</section>
</BaseLayout>
