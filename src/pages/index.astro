---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/studio/ContentCard.astro';
import {
	getActiveServices,
	getPublicResearch,
	getPublishedImageNotes,
	getPublishedWriting,
} from '../lib/content-api';
import { homePage, researchPrograms } from '../lib/site';

const services = await getActiveServices();
const writing = await getPublishedWriting();
const imageNotes = await getPublishedImageNotes();
const research = await getPublicResearch();

const featuredWriting = writing[0];
const featuredResearch = research[0];
const featuredImageNote = imageNotes[0];
const hasSelectedSurface = Boolean(featuredWriting || featuredResearch || featuredImageNote);
---

<BaseLayout title="Chromi Kingdom">
	<section class="grid gap-10 pt-8 lg:grid-cols-12">
		<div class="lg:col-span-8">
			<div class="editorial-rule">
				<p class="section-label">{homePage.hero.kicker}</p>
				<h1 class="mt-5 max-w-5xl text-[3.2rem] leading-[0.9] sm:text-[4.6rem] lg:text-[5.8rem]">
					{homePage.hero.title}
				</h1>
				<p class="mt-7 max-w-3xl text-[1.08rem] leading-8 text-ink/78 sm:text-[1.2rem]">
					{homePage.hero.intro}
				</p>

				<div class="mt-9 flex flex-wrap gap-5">
					<a
						href={homePage.hero.primaryCta.href}
						class="inline-flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-ink no-underline transition hover:text-rust"
					>
						<span aria-hidden="true">→</span>
						{homePage.hero.primaryCta.label}
					</a>
					<a
						href={homePage.hero.secondaryCta.href}
						class="inline-flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-ash no-underline transition hover:text-rust"
					>
						<span aria-hidden="true">→</span>
						{homePage.hero.secondaryCta.label}
					</a>
				</div>
			</div>
		</div>

		<aside class="lg:col-span-4">
			<div class="visual-well surface-card h-full px-6 py-6">
				<p class="section-label">{homePage.heroRail.label}</p>
				<ol class="mt-6 space-y-3 font-mono text-[0.8rem] uppercase tracking-[0.18em] text-ink/78">
					{homePage.heroRail.items.map((item) => <li>{item}</li>)}
				</ol>
				<p class="mt-10 border-t border-black/10 pt-5 text-sm leading-7 text-ink/72">
					{homePage.heroRail.note}
				</p>
			</div>
		</aside>
	</section>

	<section class="mt-20 grid gap-8 lg:grid-cols-[minmax(0,0.46fr)_minmax(0,1fr)]">
		<div class="editorial-rule">
			<p class="section-label">{homePage.work.kicker}</p>
			<h2 class="mt-4 text-[2.5rem] leading-tight sm:text-[3rem]">{homePage.work.title}</h2>
			<p class="mt-4 max-w-xl text-[1.02rem] leading-8 text-ink/74">{homePage.work.intro}</p>
			<a
				href="/work"
				class="mt-6 inline-flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-rust no-underline transition hover:text-shadow"
			>
				<span aria-hidden="true">→</span>
				{homePage.work.linkLabel}
			</a>
		</div>

		<div class="border-t border-black/10">
			{
				services.map((service, index) => (
					<a
						href={`/work#${service.data.slug}`}
						class="group grid gap-3 border-b border-black/10 py-5 text-ink no-underline sm:grid-cols-[3.5rem_minmax(0,1fr)]"
					>
						<span class="font-mono text-[0.78rem] uppercase tracking-[0.2em] text-ash">
							{String(index + 1).padStart(2, '0')}
						</span>
						<div>
							<h3 class="font-display text-[1.9rem] leading-tight transition group-hover:translate-x-1 group-hover:text-rust sm:text-[2.15rem]">
								{service.data.title}
							</h3>
							<p class="mt-3 max-w-3xl text-[1rem] leading-7 text-ink/74">{service.data.summary}</p>
						</div>
					</a>
				))
			}
		</div>
	</section>

	{
		hasSelectedSurface && (
			<section class="mt-20 grid gap-8 lg:grid-cols-[minmax(0,0.46fr)_minmax(0,1fr)]">
				<div class="editorial-rule">
					<p class="section-label">{homePage.selected.kicker}</p>
					<h2 class="mt-4 text-[2.5rem] leading-tight sm:text-[3rem]">{homePage.selected.title}</h2>
					<p class="mt-4 max-w-xl text-[1.02rem] leading-8 text-ink/74">{homePage.selected.intro}</p>
				</div>

				<div class="border-t border-black/10">
					{featuredWriting && (
						<ContentCard
							href={`/journal/${featuredWriting.data.slug}`}
							kicker={featuredWriting.data.type.replaceAll('_', ' ')}
							title={featuredWriting.data.title}
							summary={featuredWriting.data.summary}
							meta={featuredWriting.data.date.toISOString().slice(0, 10)}
							tags={featuredWriting.data.tags}
						/>
					)}
					{featuredResearch && (
						<ContentCard
							href={`/research/${featuredResearch.data.slug}`}
							kicker="Research"
							title={featuredResearch.data.title}
							summary={featuredResearch.data.summary}
							meta={String(featuredResearch.data.year)}
							tags={featuredResearch.data.themes}
						/>
					)}
					{featuredImageNote && (
						<ContentCard
							href={`/journal/${featuredImageNote.data.slug}`}
							kicker="Image note"
							title={featuredImageNote.data.title}
							summary={featuredImageNote.data.summary}
							meta={featuredImageNote.data.date.toISOString().slice(0, 10)}
							tags={featuredImageNote.data.tags}
						/>
					)}
				</div>
			</section>
		)
	}

	<section class="mt-20 grid gap-8 lg:grid-cols-[minmax(0,0.46fr)_minmax(0,1fr)]">
		<div class="editorial-rule">
			<p class="section-label">{homePage.researchProgram.kicker}</p>
			<h2 class="mt-4 text-[2.5rem] leading-tight sm:text-[3rem]">{homePage.researchProgram.title}</h2>
			<p class="mt-4 max-w-xl text-[1.02rem] leading-8 text-ink/74">{homePage.researchProgram.intro}</p>
		</div>

		<div class="grid gap-5 border-t border-black/10 pt-1 lg:grid-cols-3">
			{
				researchPrograms.map((program) => (
					<div class="border-t border-black/10 pt-4">
						<p class="section-label">Program</p>
						<h3 class="mt-4 font-display text-[1.9rem] leading-tight">{program.title}</h3>
						<p class="mt-4 text-[0.98rem] leading-7 text-ink/74">{program.summary}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="mt-20 grid gap-8 border-t border-black/10 pt-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
		<div>
			<p class="section-label">{homePage.contact.kicker}</p>
			<h2 class="mt-4 max-w-4xl text-[2.6rem] leading-tight sm:text-[3.1rem]">{homePage.contact.title}</h2>
			<p class="mt-4 max-w-2xl text-[1.02rem] leading-8 text-ink/74">{homePage.contact.intro}</p>
		</div>
		<a
			href={homePage.contact.ctaHref}
			class="inline-flex items-center gap-3 font-mono text-[0.72rem] uppercase tracking-[0.22em] text-rust no-underline transition hover:text-shadow"
		>
			<span aria-hidden="true">→</span>
			{homePage.contact.ctaLabel}
		</a>
	</section>
</BaseLayout>
