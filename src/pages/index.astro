---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/studio/ContentCard.astro';
import {
	getActiveServices,
	getPublicResearch,
	getPublishedImageNotes,
	getPublishedWriting,
} from '../lib/content-api';
import { homePage, researchPrograms } from '../lib/site';

const services = await getActiveServices();
const writing = await getPublishedWriting();
const imageNotes = await getPublishedImageNotes();
const research = await getPublicResearch();

const featuredWriting = writing[0];
const featuredResearch = research[0];
const featuredImageNote = imageNotes[0];
const hasSelectedSurface = Boolean(featuredWriting || featuredResearch || featuredImageNote);
---

<BaseLayout title="Chromi Kingdom">
	<section class="pt-10">
		<p class="max-w-xl font-mono text-[0.86rem] font-semibold uppercase leading-tight text-ink">
			AI adoption is a governance event before it is a product event.
		</p>

		<div class="protocol-field mt-10 min-h-[52rem] px-5 py-8 sm:px-10 lg:grid lg:grid-cols-[minmax(0,1fr)_24rem] lg:items-center lg:px-20">
			<div>
				<p class="section-label">{homePage.hero.kicker}</p>
				<h1 class="protocol-title mt-20 max-w-5xl text-[3.6rem] leading-[0.86] sm:text-[5.2rem] lg:text-[6.2rem]">
					Clarify <span class="protocol-highlight">what should not be built</span> before deciding what can be automated.
				</h1>
			</div>

			<aside class="mt-12 lg:mt-0">
				<div class="border-t border-black/30">
					{
						homePage.heroRail.items.map((item) => {
							const [code, ...rest] = item.split('  ');
							return (
								<div class="grid grid-cols-[3.5rem_1fr] gap-5 border-b border-black/25 py-4 font-mono text-[0.72rem] uppercase text-ink">
									<span>{code}</span>
									<span>{rest.join(' ')}</span>
								</div>
							);
						})
					}
				</div>
				<p class="mt-8 max-w-[19rem] text-[1rem] leading-7 text-ink/70">{homePage.heroRail.note}</p>
			</aside>
		</div>
	</section>

	<section class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
		<a href="/work" class="group border-t border-black/80 pt-5 text-ink no-underline">
			<p class="section-label">Work / 01</p>
			<h2 class="protocol-title mt-20 text-[2.25rem] leading-[0.9] group-hover:text-rust">Diagnosis</h2>
			<p class="mt-4 font-mono text-[0.72rem] uppercase leading-6">Decision frame before prototype.</p>
		</a>
		<a href="/work" class="group border-t border-black/80 pt-5 text-ink no-underline">
			<p class="section-label">Work / 02</p>
			<h2 class="protocol-title mt-20 text-[2.25rem] leading-[0.9] group-hover:text-rust">Audit</h2>
			<p class="mt-4 font-mono text-[0.72rem] uppercase leading-6">Failure surface before integration.</p>
		</a>
		<a href="/journal" class="group border-t border-black/80 pt-5 text-ink no-underline">
			<p class="section-label">Journal / 03</p>
			<h2 class="protocol-title mt-20 text-[2.25rem] leading-[0.9] group-hover:text-rust">Writing</h2>
			<p class="mt-4 font-mono text-[0.72rem] uppercase leading-6">Notes, cases, public warnings.</p>
		</a>
		<a href="/contact" class="group border-t border-black/80 pt-5 text-ink no-underline">
			<p class="section-label">Contact / 04</p>
			<h2 class="protocol-title mt-20 text-[2.25rem] leading-[0.9] group-hover:text-rust">Inquiry</h2>
			<p class="mt-4 font-mono text-[0.72rem] uppercase leading-6">Send the decision first.</p>
		</a>
	</section>

	<section class="mt-24 grid gap-8 lg:grid-cols-[minmax(0,0.58fr)_minmax(0,1fr)]">
		<div class="editorial-rule">
			<p class="section-label">{homePage.work.kicker}</p>
			<h2 class="protocol-title mt-4 text-[2.8rem] leading-[0.9] sm:text-[4rem]">{homePage.work.title}</h2>
			<p class="mt-5 max-w-xl text-[1.08rem] leading-8 text-ink/74">{homePage.work.intro}</p>
			<a href="/work" class="protocol-link mt-7">
				<span aria-hidden="true">→</span>
				{homePage.work.linkLabel}
			</a>
		</div>

		<div class="protocol-ledger">
			{
				services.map((service, index) => (
					<a href={`/work#${service.data.slug}`} class="protocol-ledger-row group text-ink no-underline">
						<span class="font-mono text-[0.78rem] uppercase text-ash">{String(index + 1).padStart(2, '0')}</span>
						<h3 class="protocol-title text-[2rem] leading-[0.92] group-hover:text-rust sm:text-[2.65rem]">{service.data.title}</h3>
						<p class="text-[0.95rem] leading-7 text-ink/72">{service.data.summary}</p>
					</a>
				))
			}
		</div>
	</section>

	{
		hasSelectedSurface && (
			<section class="mt-24 grid gap-8 lg:grid-cols-[minmax(0,0.46fr)_minmax(0,1fr)]">
				<div class="editorial-rule">
					<p class="section-label">{homePage.selected.kicker}</p>
					<h2 class="protocol-title mt-4 text-[2.8rem] leading-[0.9] sm:text-[4rem]">{homePage.selected.title}</h2>
					<p class="mt-5 max-w-xl text-[1.08rem] leading-8 text-ink/74">{homePage.selected.intro}</p>
				</div>

				<div class="border-t border-black/35">
					{featuredWriting && (
						<ContentCard
							href={`/journal/${featuredWriting.data.slug}`}
							kicker={featuredWriting.data.type.replaceAll('_', ' ')}
							title={featuredWriting.data.title}
							summary={featuredWriting.data.summary}
							meta={featuredWriting.data.date.toISOString().slice(0, 10)}
							tags={featuredWriting.data.tags}
						/>
					)}
					{featuredResearch && (
						<ContentCard
							href={`/research/${featuredResearch.data.slug}`}
							kicker="Research"
							title={featuredResearch.data.title}
							summary={featuredResearch.data.summary}
							meta={String(featuredResearch.data.year)}
							tags={featuredResearch.data.themes}
						/>
					)}
					{featuredImageNote && (
						<ContentCard
							href={`/journal/${featuredImageNote.data.slug}`}
							kicker="Image note"
							title={featuredImageNote.data.title}
							summary={featuredImageNote.data.summary}
							meta={featuredImageNote.data.date.toISOString().slice(0, 10)}
							tags={featuredImageNote.data.tags}
						/>
					)}
				</div>
			</section>
		)
	}

	<section class="mt-24 grid gap-8 lg:grid-cols-[minmax(0,0.46fr)_minmax(0,1fr)]">
		<div class="editorial-rule">
			<p class="section-label">{homePage.researchProgram.kicker}</p>
			<h2 class="protocol-title mt-4 text-[2.8rem] leading-[0.9] sm:text-[4rem]">{homePage.researchProgram.title}</h2>
			<p class="mt-5 max-w-xl text-[1.08rem] leading-8 text-ink/74">{homePage.researchProgram.intro}</p>
		</div>

		<div class="grid gap-5 border-t border-black/35 pt-1 lg:grid-cols-3">
			{
				researchPrograms.map((program, index) => (
					<div class="border-t border-black/35 pt-5">
						<p class="section-label">Program / {String(index + 1).padStart(2, '0')}</p>
						<h3 class="protocol-title mt-16 text-[2rem] leading-[0.92]">{program.title}</h3>
						<p class="mt-5 text-[0.98rem] leading-7 text-ink/74">{program.summary}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="mt-24 grid gap-8 border-t border-black/80 pt-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-end">
		<div>
			<p class="section-label">{homePage.contact.kicker}</p>
			<h2 class="protocol-title mt-4 max-w-4xl text-[2.8rem] leading-[0.9] sm:text-[4.1rem]">{homePage.contact.title}</h2>
			<p class="mt-5 max-w-2xl text-[1.08rem] leading-8 text-ink/74">{homePage.contact.intro}</p>
		</div>
		<a href={homePage.contact.ctaHref} class="protocol-link">
			<span aria-hidden="true">→</span>
			{homePage.contact.ctaLabel}
		</a>
	</section>
</BaseLayout>
