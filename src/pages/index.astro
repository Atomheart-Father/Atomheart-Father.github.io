---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/studio/ContentCard.astro';
import PageHero from '../components/studio/PageHero.astro';
import { getActiveServices, getPublicResearch, getPublishedSamples } from '../lib/content-api';
import { homePage, researchPrograms } from '../lib/site';

const services = await getActiveServices();
const samples = await getPublishedSamples();
const research = await getPublicResearch();
const featuredSample = samples[0];
const featuredResearch = research[0];
const secondaryCta = samples.length > 0 ? homePage.hero.secondaryCta : undefined;
---

<BaseLayout title="Chromi Kingdom">
	<PageHero
		kicker={homePage.hero.kicker}
		title={homePage.hero.title}
		intro={homePage.hero.intro}
		primaryCta={homePage.hero.primaryCta}
		secondaryCta={secondaryCta}
	/>

	<section class="mt-16 space-y-6">
		<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
			<div>
				<p class="section-label">{homePage.services.kicker}</p>
				<h2 class="mt-3 text-[2.5rem] leading-tight sm:text-[3rem]">{homePage.services.title}</h2>
				<p class="mt-4 max-w-2xl text-[1.02rem] leading-8 text-ink/74">{homePage.services.intro}</p>
			</div>
			<a href="/services" class="text-sm tracking-[0.14em] text-rust no-underline transition hover:text-shadow">
				{homePage.services.linkLabel}
			</a>
		</div>

		<div class="grid gap-5 lg:grid-cols-3">
			{
				services.map((service) => (
					<ContentCard
						href={`/services#${service.data.slug}`}
						kicker="Service"
						title={service.data.title}
						summary={service.data.summary}
						tags={service.data.deliverables.slice(0, 2)}
					/>
				))
			}
		</div>
	</section>

	{
		(featuredSample || featuredResearch) && (
			<section class="mt-16 space-y-6">
				<div>
					<p class="section-label">{homePage.featured.kicker}</p>
					<h2 class="mt-3 text-[2.5rem] leading-tight sm:text-[3rem]">{homePage.featured.title}</h2>
					<p class="mt-4 max-w-2xl text-[1.02rem] leading-8 text-ink/74">{homePage.featured.intro}</p>
				</div>

				<div class="grid gap-5 lg:grid-cols-2">
					{featuredSample && (
						<ContentCard
							href={`/samples/${featuredSample.data.slug}`}
							kicker="Sample"
							title={featuredSample.data.title}
							summary={featuredSample.data.summary}
							meta={featuredSample.data.date.toISOString().slice(0, 10)}
							tags={featuredSample.data.tags}
						/>
					)}
					{featuredResearch && (
						<ContentCard
							href={`/research/${featuredResearch.data.slug}`}
							kicker="Research"
							title={featuredResearch.data.title}
							summary={featuredResearch.data.summary}
							meta={String(featuredResearch.data.year)}
							tags={featuredResearch.data.themes}
						/>
					)}
				</div>
			</section>
		)
	}

	<section class="mt-16 space-y-6">
		<div>
			<p class="section-label">{homePage.researchProgram.kicker}</p>
			<h2 class="mt-3 text-[2.5rem] leading-tight sm:text-[3rem]">{homePage.researchProgram.title}</h2>
			<p class="mt-4 max-w-3xl text-[1.02rem] leading-8 text-ink/74">{homePage.researchProgram.intro}</p>
		</div>

		<div class="grid gap-5 lg:grid-cols-3">
			{
				researchPrograms.map((program) => (
					<ContentCard kicker="Program" title={program.title} summary={program.summary} />
				))
			}
		</div>
	</section>

	<section class="mt-16">
		<div class="surface-card grid gap-6 px-6 py-7 sm:px-8 sm:py-9 lg:grid-cols-[1fr_auto] lg:items-center">
			<div>
				<p class="section-label">{homePage.contact.kicker}</p>
				<h2 class="mt-3 text-[2.5rem] leading-tight sm:text-[3rem]">{homePage.contact.title}</h2>
				<p class="mt-4 max-w-2xl text-[1.02rem] leading-8 text-ink/74">{homePage.contact.intro}</p>
			</div>
			<a href={homePage.contact.ctaHref} class="inline-flex rounded-full bg-ink px-5 py-3 text-sm tracking-[0.12em] text-paper no-underline transition hover:bg-shadow">
				{homePage.contact.ctaLabel}
			</a>
		</div>
	</section>
</BaseLayout>
