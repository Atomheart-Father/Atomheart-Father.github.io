---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/studio/PageHero.astro';
import { aboutPage, researchPrograms, siteMeta } from '../lib/site';
---

<BaseLayout title="About" description="About the research-driven AI Studio structure behind Chromi Kingdom.">
	<PageHero
		kicker={aboutPage.hero.kicker}
		title={aboutPage.hero.title}
		intro={aboutPage.hero.intro}
	/>

	<section class="mt-12 grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
		<div class="editorial-rule">
			<p class="section-label">Current work</p>
			<p class="mt-5 text-[1.04rem] leading-8 text-ink/76">{aboutPage.current}</p>
		</div>

		<div class="editorial-rule">
			<p class="section-label">{aboutPage.focusTitle}</p>
			<ul class="mt-5 space-y-4 text-[1.02rem] leading-8 text-ink/76">
				{
					researchPrograms.map((program) => (
						<li class="flex gap-3">
							<span class="mt-[0.9rem] h-1.5 w-1.5 rounded-full bg-rust"></span>
							<span>{program.title}</span>
						</li>
					))
				}
			</ul>
		</div>
	</section>

	<section class="mt-12 grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
		<div class="editorial-rule">
			<p class="section-label">{aboutPage.journalTitle}</p>
			<p class="mt-5 text-[1.04rem] leading-8 text-ink/76">{aboutPage.journalIntro}</p>
		</div>

		<div class="editorial-rule">
			<p class="section-label">{aboutPage.linksTitle}</p>
			<ul class="mt-5 flex flex-wrap gap-4 text-[1.02rem] leading-8 text-ink/76">
				<li>
					<a href={`mailto:${siteMeta.email}`} class="text-rust no-underline transition hover:text-shadow">
						{siteMeta.email}
					</a>
				</li>
				<li>
					<a href={siteMeta.orcid} target="_blank" rel="noreferrer" class="text-rust no-underline transition hover:text-shadow">
						ORCID
					</a>
				</li>
				<li>
					<a href={siteMeta.github} target="_blank" rel="noreferrer" class="text-rust no-underline transition hover:text-shadow">
						GitHub
					</a>
				</li>
			</ul>
		</div>
	</section>
</BaseLayout>
